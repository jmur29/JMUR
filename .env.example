GHL_API_KEY=your-ghl-api-key-here
GHL_LOCATION_ID=8VBD3WwolH8VNCeWr41b

# Workflow IDs per deal type
GHL_WORKFLOW_SWITCH=232600ff-7541-491f-934b-b1d218e4a6be
