# ── Google / Gmail + Sheets OAuth2 ───────────────────────────────────────────
# Paste the full JSON content of your credentials.json (single line)
GOOGLE_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["http://localhost"]}}

# Paste the full JSON content of your token.json (generated by `npm run auth`)
GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}

# ── Google Sheets Pipeline Tracker ────────────────────────────────────────────
# The ID from your Google Sheet URL: .../spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=1NCbFFwUeO-AioAi3zv-ilqxanRlLlNTwzDPCZRKYdDc

# ── Daily Report ──────────────────────────────────────────────────────────────
# Email address to receive the 8am daily pipeline report
REPORT_EMAIL=jaker.murray96@gmail.com

# Set to "true" to send a report immediately on startup (useful for testing)
REPORT_ON_STARTUP=false

# Gmail SMTP credentials for sending the daily report via Nodemailer.
# SMTP_USER: the Gmail address to send from
# SMTP_PASS: a Gmail App Password (not your regular password).
#   Generate one at: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_USER=jaker.murray96@gmail.com
SMTP_PASS=your-gmail-app-password-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info

# Set to "true" to log every unread email (sender + subject) seen during polling.
# Useful for verifying Gmail connectivity and checking what emails are arriving.
# Set back to "false" (or remove) once confirmed working.
DEBUG_ALL_EMAILS=false
