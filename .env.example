GOOGLE_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# Paste the full JSON content of your token.json (generated by `npm run auth`)
GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}

# ── Optional ──────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info
