# =============================================================
# ClearPath UW — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://clearpath:clearpath_dev@localhost:5432/clearpath_uw

# Docker Compose database config (if using docker-compose)
POSTGRES_USER=clearpath
POSTGRES_PASSWORD=clearpath_dev
POSTGRES_DB=clearpath_uw

# ─── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# ─── Clerk Authentication ─────────────────────────────────────
# Get these from https://dashboard.clerk.com
# Secret key for server-side Clerk operations
CLERK_SECRET_KEY=sk_test_...

# Webhook secret for verifying Clerk webhook signatures
# Set up a webhook endpoint in Clerk dashboard pointing to /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Frontend (Vite) ──────────────────────────────────────────
# Publishable key from Clerk dashboard (safe to expose in frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:3001

# ─── AWS S3 (Document Storage) ────────────────────────────────
# AWS credentials with S3 read/write permissions
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ca-central-1

# S3 bucket name for document uploads
S3_BUCKET=clearpath-uw-documents

# ─── Encryption ───────────────────────────────────────────────
# AES-256 encryption key for SIN (Social Insurance Numbers)
# Must be exactly 32 bytes (64 hex characters)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ─── Email (Optional) ─────────────────────────────────────────
# SMTP configuration for notifications (uses Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@yourcu.ca
SMTP_PASS=...
EMAIL_FROM=ClearPath UW <notifications@yourcu.ca>
