// ClearPath UW — Prisma Schema
// PostgreSQL + snake_case table names

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  UNDERWRITER
  BROKER
  VIEWER
}

enum ApplicationStatus {
  DRAFT
  READY_TO_SUBMIT
  SUBMITTED
  IN_REVIEW
  APPROVED
  DECLINED
  CONDITIONALLY_APPROVED
}

enum BorrowerType {
  PRIMARY
  CO_BORROWER
}

enum EmploymentType {
  EMPLOYED
  SELF_EMPLOYED
  CONTRACT
  RETIRED
  OTHER
}

enum PropertyType {
  DETACHED
  SEMI
  TOWNHOUSE
  CONDO
  DUPLEX
  OTHER
}

enum OccupancyType {
  OWNER
  RENTAL
  SECONDARY
}

enum UWDecision {
  APPROVE
  DECLINE
  MANUAL_REVIEW
}

enum DocumentType {
  PAYSTUB
  T4
  NOA
  BANK_STATEMENT
  ID
  APPRAISAL
  OTHER
}

enum DocumentStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#1a56db")
  createdAt    DateTime @default(now())

  users        User[]
  applications Application[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

model User {
  id        String    @id @default(uuid())
  tenantId  String
  clerkId   String    @unique
  firstName String
  lastName  String
  email     String    @unique
  role      UserRole  @default(VIEWER)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  assignedApplications Application[]        @relation("AssignedUnderwriter")
  createdApplications  Application[]        @relation("ApplicationCreator")
  decisions            UnderwritingDecision[]
  uploadedDocuments    Document[]
  auditLogs            AuditLog[]
  applicationNotes     ApplicationNote[]    @relation("NoteAuthor")
  clearedConditions    ApprovalCondition[]  @relation("ConditionClearer")
  statusChanges        StatusHistory[]      @relation("StatusHistoryUser")
  aiAuditEntries       AiAuditEntry[]

  @@index([tenantId])
  @@map("users")
}

model Application {
  id           String            @id @default(uuid())
  tenantId     String
  fileNumber   String            @unique
  status       ApplicationStatus @default(DRAFT)
  assignedToId String?
  createdById  String?
  lenderTarget String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  assignedTo       User?                @relation("AssignedUnderwriter", fields: [assignedToId], references: [id])
  createdBy        User?                @relation("ApplicationCreator", fields: [createdById], references: [id])
  borrowers        Borrower[]
  property         Property?
  mortgageTerms    MortgageTerms?
  decisions        UnderwritingDecision[]
  documents        Document[]
  auditLogs        AuditLog[]
  notes            ApplicationNote[]
  conditions       ApprovalCondition[]
  statusHistory    StatusHistory[]
  downPayments     DownPaymentEntry[]
  creditMemo       CreditMemo?
  submissionNote   SubmissionNote?

  @@index([tenantId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
  @@map("applications")
}

model Borrower {
  id                String         @id @default(uuid())
  applicationId     String
  type              BorrowerType
  firstName         String
  lastName          String
  dob               DateTime
  email             String
  phone             String
  sinEncrypted      String
  employmentType    EmploymentType
  creditScore       Int
  bankruptcies      Boolean        @default(false)
  collections       Boolean        @default(false)
  existingMortgages Int            @default(0)

  application Application @relation(fields: [applicationId], references: [id])
  income      Income?

  @@index([applicationId])
  @@map("borrowers")
}

model Income {
  id               String   @id @default(uuid())
  borrowerId       String   @unique
  employerName     String?
  jobTitle         String?
  yearsEmployed    Decimal? @db.Decimal(5, 2)
  baseSalary       Decimal  @default(0) @db.Decimal(14, 2)
  bonus            Decimal  @default(0) @db.Decimal(14, 2)
  overtime         Decimal  @default(0) @db.Decimal(14, 2)
  otherIncome      Decimal  @default(0) @db.Decimal(14, 2)
  selfEmployedAvg  Decimal? @db.Decimal(14, 2)
  rentalIncome     Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt        DateTime @updatedAt

  borrower Borrower @relation(fields: [borrowerId], references: [id])

  @@map("incomes")
}

model Property {
  id            String        @id @default(uuid())
  applicationId String        @unique
  address       String
  city          String
  province      String
  postalCode    String
  propertyType  PropertyType
  occupancy     OccupancyType
  purchasePrice Decimal       @db.Decimal(14, 2)
  appraisedValue Decimal      @db.Decimal(14, 2)
  downPayment   Decimal       @db.Decimal(14, 2)
  annualTax     Decimal       @db.Decimal(10, 2)
  monthlyHeat   Decimal       @db.Decimal(10, 2)
  condoFees     Decimal       @default(0) @db.Decimal(10, 2)
  updatedAt     DateTime      @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@map("properties")
}

model MortgageTerms {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  contractRate      Decimal  @db.Decimal(6, 4)
  stressRate        Decimal  @db.Decimal(6, 4)
  amortizationYears Int
  termYears         Int
  insured           Boolean  @default(false)
  monthlyPayment    Decimal  @db.Decimal(12, 2)
  mortgageAmount    Decimal  @db.Decimal(14, 2)
  updatedAt         DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@map("mortgage_terms")
}

model UnderwritingDecision {
  id            String     @id @default(uuid())
  applicationId String
  gds           Decimal    @db.Decimal(6, 3)
  tds           Decimal    @db.Decimal(6, 3)
  ltv           Decimal    @db.Decimal(6, 3)
  stressGds     Decimal    @db.Decimal(6, 3)
  stressTds     Decimal    @db.Decimal(6, 3)
  decision      UWDecision
  flags         Json
  notes         String?
  decidedById   String
  decidedAt     DateTime   @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  decidedBy   User        @relation(fields: [decidedById], references: [id])

  @@index([applicationId])
  @@map("underwriting_decisions")
}

model Document {
  id             String         @id @default(uuid())
  applicationId  String
  uploadedById   String
  name           String
  type           DocumentType
  s3Key          String
  url            String
  uploadedAt     DateTime       @default(now())
  status         DocumentStatus @default(PENDING)

  application      Application             @relation(fields: [applicationId], references: [id])
  uploadedBy       User                    @relation(fields: [uploadedById], references: [id])
  classification   DocumentClassification?
  fraudSignals     FraudSignal[]

  @@index([applicationId])
  @@map("documents")
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String
  applicationId String?
  action        String
  metadata      Json
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@index([userId])
  @@map("audit_logs")
}

model ApplicationNote {
  id            String   @id @default(uuid())
  applicationId String
  authorId      String
  body          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  author      User        @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([applicationId])
  @@map("application_notes")
}

model ApprovalCondition {
  id            String    @id @default(uuid())
  applicationId String
  body          String
  cleared       Boolean   @default(false)
  clearedById   String?
  clearedAt     DateTime?
  createdAt     DateTime  @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  clearedBy   User?       @relation("ConditionClearer", fields: [clearedById], references: [id])

  @@index([applicationId])
  @@map("approval_conditions")
}

model StatusHistory {
  id            String             @id @default(uuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  changedById   String
  note          String?
  createdAt     DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  changedBy   User        @relation("StatusHistoryUser", fields: [changedById], references: [id])

  @@index([applicationId])
  @@map("status_history")
}

// ─── AI & Document Intelligence Models ───────────────────────────────────────

model DocumentClassification {
  id              String   @id @default(cuid())
  tenantId        String
  documentId      String   @unique
  classifiedType  String   // T4 | NOA | PAY_STUB | BANK_STATEMENT | GIFT_LETTER | PURCHASE_AGREEMENT | EMPLOYMENT_LETTER | MORTGAGE_STATEMENT | PHOTO_ID | OTHER
  confidence      Float
  extractedFields Json     // borrowerName, employer, income, dates, accountNumbers, etc.
  rawOcrText      String?  @db.Text
  createdAt       DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([tenantId])
  @@map("document_classifications")
}

model DownPaymentEntry {
  id             String   @id @default(cuid())
  tenantId       String
  applicationId  String
  transactionDate DateTime
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  runningBalance Decimal? @db.Decimal(12, 2)
  category       String   // PAYROLL | ETRANSFER | WIRE | CASH | INVESTMENT | GIFT | GOVERNMENT | UNKNOWN
  isFlagged      Boolean  @default(false)
  flagReason     String?
  loeRequired    Boolean  @default(false)
  loeDraftText   String?  @db.Text
  createdAt      DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@map("down_payment_entries")
}

model FraudSignal {
  id                 String   @id @default(cuid())
  tenantId           String
  documentId         String
  signalType         String   // METADATA_ANOMALY | FONT_INCONSISTENCY | BALANCE_MISMATCH | EMPLOYER_MISMATCH | ROUND_NUMBER | OTHER
  severity           String   // LOW | MEDIUM | HIGH
  evidence           String   @db.Text
  recommendedAction  String   @db.Text
  aiExplanation      String?  @db.Text
  acknowledgedAt     DateTime?
  acknowledgedById   String?
  createdAt          DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([tenantId])
  @@index([documentId])
  @@map("fraud_signals")
}

model CreditMemo {
  id                   String   @id @default(cuid())
  tenantId             String
  applicationId        String   @unique
  generatedAt          DateTime @default(now())
  gds                  Decimal  @db.Decimal(5, 2)
  tds                  Decimal  @db.Decimal(5, 2)
  qualifyingRate       Decimal  @db.Decimal(5, 3)
  downPaymentTotal     Decimal  @db.Decimal(12, 2)
  downPaymentSourced   Boolean  @default(false)
  flagCount            Int      @default(0)
  fraudSignalCount     Int      @default(0)
  narrative            String?  @db.Text
  underwriterNotes     String?  @db.Text
  recommendedConditions Json?
  pdfS3Key             String?
  aiModel              String?
  promptVersion        String?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@map("credit_memos")
}

model AiAuditEntry {
  id            String   @id @default(cuid())
  tenantId      String
  applicationId String?
  documentId    String?
  action        String   // CLASSIFY_DOCUMENT | SOURCE_DOWN_PAYMENT | GENERATE_LOE | GENERATE_CREDIT_MEMO | EXPLAIN_FRAUD_SIGNAL | DRAFT_SUBMISSION_NOTES | ANTICIPATE_CONDITIONS
  aiModel       String
  promptHash    String
  responseHash  String
  inputTokens   Int?
  outputTokens  Int?
  userId        String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@index([userId])
  @@map("ai_audit_entries")
}

model SubmissionNote {
  id                    String    @id @default(cuid())
  tenantId              String
  applicationId         String    @unique
  draftText             String    @db.Text
  lenderTarget          String?
  anticipatedConditions Json?
  isFinalized           Boolean   @default(false)
  finalizedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@map("submission_notes")
}
